# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=DroughtMonitor API
VERSION=1.0.0

# CORS - Add your frontend URLs
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./droughtmonitor.db

# Cloud Storage Configuration
# Options: cloudflare-r2, aws-s3, backblaze-b2
CLOUD_STORAGE_PROVIDER=cloudflare-r2
CLOUD_STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUD_STORAGE_BUCKET=drought-data
CLOUD_STORAGE_ACCESS_KEY=your-access-key
CLOUD_STORAGE_SECRET_KEY=your-secret-key
CLOUD_STORAGE_REGION=auto

# File Upload Settings
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=[".parquet"]
UPLOAD_DIR=./uploads

# Export Settings (for CSV/PNG/JPEG exports)
EXPORT_DIR=./exports
EXPORT_MAX_AGE_HOURS=24

# Admin User - CHANGE THESE!
ADMIN_EMAIL=admin@droughtmonitor.com
ADMIN_PASSWORD=change-this-secure-password

# Cache Settings (Redis - OPTIONAL but HIGHLY RECOMMENDED for large datasets)
# If not set, will use in-memory cache (less efficient)
REDIS_URL=
# Examples:
# Local: redis://localhost:6379/0
# Upstash: redis://default:password@endpoint.upstash.io:6379
# Redis Cloud: redis://:password@host:port
CACHE_DEFAULT_EXPIRE=900
